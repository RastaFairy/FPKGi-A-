<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- API 29+ theme that actually exists. Using Material.Light.NoActionBar avoids
         the "style not found" link error while keeping the dark Compose surface. -->
    <style name="Theme.FPKGiManager" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
